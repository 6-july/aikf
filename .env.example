DATABASE_URL=postgresql://uu_runner:uu_runner_dev@localhost:5432/uu_runner_ai_cs

# local | ark | volcano
EMBEDDING_PROVIDER=local
EMBEDDING_DIMENSION=2048
EMBEDDING_STORAGE_TYPE=halfvec

# 火山 Ark 向量模型，按 OpenAI-compatible embeddings 接口调用：
# POST {ARK_EMBEDDING_BASE_URL}/embeddings
ARK_EMBEDDING_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_EMBEDDING_API_KEY=
ARK_EMBEDDING_MODEL=
ARK_EMBEDDING_DIMS=2048
ARK_EMBEDDING_API_TYPE=multi_modal_api

# 兼容旧变量名，可不填。
VOLCANO_EMBEDDING_BASE_URL=
VOLCANO_EMBEDDING_API_KEY=
VOLCANO_EMBEDDING_MODEL=
